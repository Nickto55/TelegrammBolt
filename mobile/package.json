{
  "name": "telegrambolt-mobile",
  "version": "1.0.0",
  "description": "Mobile application for TelegrammBolt (iOS & Android)",
  "main": "node_modules/expo/AppEntry.js",
  "homepage": "https://github.com/your-repo/telegrambolt-mobile",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "lint": "eslint .",
    "test": "jest",
    "deploy": "eas build --platform all",
    "android-build": "expo prebuild --platform android && cd android && ./gradlew assembleRelease",
    "android-build-debug": "expo prebuild --platform android && cd android && ./gradlew assembleDebug",
    "android-clean": "cd android && ./gradlew clean"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.21.0",
    "@react-navigation/bottom-tabs": "~6.5.11",
    "@react-navigation/drawer": "~6.6.7",
    "@react-navigation/native": "~6.1.9",
    "@react-navigation/native-stack": "^6.11.0",
    "@react-navigation/stack": "~6.3.20",
    "axios": "^1.6.0",
    "date-fns": "~2.30.0",
    "expo": "~50.0.0",
    "expo-camera": "~14.1.3",
    "expo-file-system": "~16.0.9",
    "expo-secure-store": "~12.8.1",
    "expo-sharing": "~11.10.0",
    "expo-status-bar": "~1.11.1",
    "formik": "~2.4.0",
    "react": "18.2.0",
    "react-native": "0.73.6",
    "react-native-gesture-handler": "~2.14.0",
    "react-native-screens": "~3.29.0",
    "react-native-svg": "14.1.0",
    "react-native-vector-icons": "~10.0.0",
    "yup": "~1.3.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "jest": "^29.7.0"
  },
  "eslintConfig": {
    "extends": "@react-native-community"
  },
  "jest": {
    "preset": "jest-expo"
  }
}
